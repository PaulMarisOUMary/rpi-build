# Compose build settings (optional)
DOCKER_DEBIAN_VERSION=trixie
DOCKER_RPI_IMAGE_GEN_VERSION=master

# Sandbox settings
_SANDBOX_TARGET_NAME=rpi3-slim-test
SANDBOX_ARTIFACT_CONTEXT=${_SANDBOX_TARGET_NAME}
SANDBOX_ARTIFACT_NAME=${_SANDBOX_TARGET_NAME}.tgz
SANDBOX_IMAGE_NAME=
SANDBOX_DIR_CONTEXT=

# Target (required)
_TARGET_NAME=rpi3-slim
TARGET_FOLDER=rpi3-slim
TARGET_CONFIG=${_TARGET_NAME}.yaml

# Extra build args (optional)
# e.g. "-I -f", space separated
# note: "-f" requires image within the target config
EXTRA_ARGS=

# Output image name (required)
IMAGE_NAME=${_TARGET_NAME}

# Device config (required)
DEVICE_HOSTNAME="slim"
DEVICE_USERNAME="pi"
DEVICE_PASSWORD="ChangeMe123!"

# WiFi config (optional)
WIFI_SSID="MySSID"
WIFI_PASSPHRASE="MyP@55PHR@S3"
