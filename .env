# Compose build settings (optional)
DOCKER_DEBIAN_VERSION=trixie
DOCKER_RPI_IMAGE_GEN_VERSION=master

# Target (required)
_TARGET_NAME=rpi3-slim
TARGET_FOLDER=${_TARGET_NAME}
TARGET_CONFIG=${_TARGET_NAME}.yaml

# Extra build args (optional)
EXTRA_ARGS="-I"

# Output image name (required)
IMAGE_NAME=${_TARGET_NAME}

# Device config (required)
DEVICE_HOSTNAME=slim
DEVICE_USERNAME=pi
DEVICE_PASSWORD=ChangeMe123!
